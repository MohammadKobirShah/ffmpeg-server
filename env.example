# Copy to .env and edit. Compose auto-loads it.
# Everything is OPTIONAL — leave blank for default Quick Tunnel.

# ─── Cloudflare Tunnel ─────────────────────────────────────
# Mode 1 (default if both empty): Quick Tunnel → random *.trycloudflare.com URL
#
# Mode 2: Named tunnel via TOKEN (recommended for production)
#   1. Cloudflare Zero Trust → Networks → Tunnels → Create tunnel → copy token
#   2. Add a public hostname route pointing to http://nginx:8080
#   3. Set TUNNEL_TOKEN and PUBLIC_DOMAIN below
#TUNNEL_TOKEN=eyJhIjoiXXXXXXXXXXXXXXXXXXXXXX...
#PUBLIC_DOMAIN=https://hls.yourdomain.com

# Edge protocol — http2 is the most compatible; quic is fastest if your
# network allows UDP egress; auto lets cloudflared decide.
TUNNEL_PROTOCOL=http2

# Edge region — leave blank for fastest auto-routing. Force with: us
TUNNEL_REGION=

# Extra cloudflared CLI args (rare; e.g. --loglevel debug)
TUNNEL_EXTRA_ARGS=
